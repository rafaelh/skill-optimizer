from __future__ import annotations

import argparse
import json
import sys
from dataclasses import asdict, dataclass
from typing import Any

# ---------------------------------------------------------------------------
# Exit code constants — use these, never bare integers
# ---------------------------------------------------------------------------
EXIT_OK = 0
EXIT_USER_ERROR = 1
EXIT_SYSTEM_ERROR = 2
EXIT_NOT_FOUND = 3

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

def _emit_error(error: str, code: str, hint: str = "") -> None:
    """Write a structured error to stderr. Never write errors to stdout."""
    payload: dict[str, str] = {"error": error, "code": code}
    if hint:
        payload["hint"] = hint
    print(json.dumps(payload), file=sys.stderr)


def _log(msg: str, quiet: bool = False) -> None:
    """Write informational message to stderr, suppressed by --quiet."""
    if not quiet:
        print(msg, file=sys.stderr)


# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------

@dataclass
class Record:
    """One result record. Add or remove fields to match your domain."""
    id: str
    name: str
    # ... add domain fields here


# For a single-record tool (fetch-one), replace `data: list[Record]` with
# `data: Record`, drop `total` / `next_cursor`, and adjust to_json_payload to
# serialise one record. The "data may be an object rather than an array" rule
# from the interface contract applies here.
@dataclass
class ResultSet:
    data: list[Record]
    count: int
    total: int | None = None
    next_cursor: str | None = None

    def to_json_payload(self, fields: list[str] | None = None) -> dict[str, Any]:
        records = [asdict(r) for r in self.data]
        if fields:
            keep = frozenset(fields)
            records = [{k: v for k, v in r.items() if k in keep} for r in records]
        return {
            "data": records,
            "meta": {
                "count": self.count,
                "total": self.total,
                "next_cursor": self.next_cursor,
            },
        }


